{
  "name": "eventhive-server",
  "version": "1.0.0",
  "description": "EventHive Backend API - Node.js + Express + PostgreSQL",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "db:migrate": "psql -U postgres -d eventhive -f ../database/migrations/schema.sql",
    "db:seed": "psql -U postgres -d eventhive -f ../database/seeders/seed.sql"
  },
  "keywords": [
    "eventhive",
    "events",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "uuid": "^14.0.1"
  }
}
