# ─── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
# URL of the Vite dev server (used for CORS)
CLIENT_URL=http://localhost:5173

# ─── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventhive
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false

# ─── JWT ─────────────────────────────────────────────
# Use a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_characters
JWT_EXPIRES=7d

# ─── Firebase Admin SDK ───────────────────────────────
# Found in Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com

# ─── Google Gemini AI ─────────────────────────────────
# Found in Google AI Studio → Get API key
GEMINI_API_KEY=your_gemini_api_key

# ─── Groq AI ──────────────────────────────────────────
# Found at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
